      "source": [
        "# B.3 — Media por asignatura\n",
        "# Inicializamos un diccionario vacío para almacenar las notas de cada asignatura.\n",
        "# Las claves serán los nombres de las asignaturas y los valores serán listas de notas.\n",
        "notas_por_asignatura = {}\n",
        "\n",
        "# Iteramos a través de cada estudiante en la lista 'estudiantes'.\n",
        "for estudiante in estudiantes:\n",
        "    # Obtenemos la asignatura del estudiante actual.\n",
        "    asignatura = estudiante['asignatura']\n",
        "    # Obtenemos la nota del estudiante actual.\n",
        "    nota = estudiante['nota']\n",
        "\n",
        "    # Si la asignatura aún no está en nuestro diccionario 'notas_por_asignatura',\n",
        "    # la añadimos con una lista vacía como su valor.\n",
        "    if asignatura not in notas_por_asignatura:\n",
        "        notas_por_asignatura[asignatura] = []\n",
        "    # Añadimos la nota del estudiante a la lista correspondiente a su asignatura.\n",
        "    notas_por_asignatura[asignatura].append(nota)\n",
        "\n",
        "# Usamos una comprensión de diccionario para calcular la media de cada asignatura.\n",
        "# Para cada asignatura (clave) y su lista de notas (valor) en 'notas_por_asignatura':\n",
        "# 1. Sumamos todas las notas de la lista (sum(notas)).\n",
        "# 2. Dividimos la suma por el número de notas en la lista (len(notas)) para obtener la media.\n",
        "# 3. Redondeamos el resultado a 2 decimales (round(..., 2)).\n",
        "# El resultado es un nuevo diccionario donde las claves son las asignaturas y los valores son sus notas medias.\n",
        "media_por_asignatura = {asignatura: round(sum(notas) / len(notas), 2)\n",
