      "outputs": [],
      "source": [
        "def filtrar_pares(numeros: list[int]) -> list[int]:\n",
        "    # Inicializa una lista vacía para almacenar los números pares.\n",
        "    pares = []\n",
        "    # Itera sobre cada número en la lista de entrada.\n",
        "    for numero in numeros:\n",
        "        # Comprueba si el número es par usando el operador módulo (%).\n",
        "        # Si el residuo de la división por 2 es 0, el número es par.\n",
        "        if numero % 2 == 0:\n",
        "            # Si es par, añade el número a la lista 'pares'.\n",
        "            pares.append(numero)\n",
        "    # Devuelve la lista con todos los números pares encontrados.\n",
        "    return pares"
      ]
    },
