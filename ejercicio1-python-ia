      "outputs": [],
      "source": [
        "def invertir_diccionario(d: dict) -> dict:\n",
        "    # Inicializa un diccionario vacío para almacenar el resultado invertido.\n",
        "    diccionario_invertido = {}\n",
        "    # Itera sobre cada par clave-valor en el diccionario de entrada.\n",
        "    for clave, valor in d.items():\n",
        "        # Asigna el valor como nueva clave y la clave original como nuevo valor.\n",
        "        # Si un valor ya existe como clave en diccionario_invertido, se sobrescribirá\n",
        "        # con la clave actual, lo que asegura que se \"queda con el último\" en caso de duplicados.\n",
        "        diccionario_invertido[valor] = clave\n",
        "    # Devuelve el diccionario con las claves y valores invertidos.\n",
        "    return diccionario_invertido"
      ]
    },
