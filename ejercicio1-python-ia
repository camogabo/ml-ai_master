        "### A.4 — Aplanar lista anidada (10 pts)\n",
        "\n",
        "Crea una función `aplanar(lista)` que reciba una lista que puede contener sublistas y devuelva una lista plana con todos los elementos."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 9,
      "metadata": {
        "id": "_4MlMoHLdNqb"
      },
      "outputs": [],
      "source": [
        "def aplanar(lista: list) -> list:\n",
        "    # Inicializamos una lista vacía para guardar el resultado aplanado.\n",
        "    resultado = []\n",
        "    # Iteramos sobre cada elemento de la lista de entrada.\n",
        "    for elemento in lista:\n",
        "        # Comprobamos si el elemento actual es una lista.\n",
        "        if isinstance(elemento, list):\n",
        "            # Si es una lista, llamamos recursivamente a 'aplanar' en esta sublista\n",
        "            # y extendemos el resultado a nuestra lista principal 'resultado'.\n",
        "            resultado.extend(aplanar(elemento))\n",
        "        else:\n",
        "            # Si no es una lista (es un elemento simple), lo añadimos directamente a 'resultado'.\n",
        "            resultado.append(elemento)\n",
        "    # Devolvemos la lista aplanada.\n",
        "    return resultado"
      ]
    },
